# Tailscale bind IP (private only)
DASHBOARD_BIND_IP=100.90.28.62

# Dashboard port (single container serves API + UI)
PORT=3100

# Dashboard UI auth (JWT)
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=admin123
JWT_SECRET=change-this-secret
JWT_EXPIRES=8h

# API key for OpenClaw -> Dashboard automation calls
DASHBOARD_API_KEY=change-this-api-key

# Workspace mount (read-only in container)
WORKSPACE_ROOT=/workspace

# SQLite path (volume)
DB_PATH=/data/dashboard.sqlite

# OpenClaw upstream (private)
OPENCLAW_BASE_URL=http://127.0.0.1:18789
OPENCLAW_WS_URL=ws://127.0.0.1:18789
OPENCLAW_GATEWAY_TOKEN=
# fallback (Coolify):
SERVICE_PASSWORD_64_GATEWAYTOKEN=
